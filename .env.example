# ── LiveKit ─────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# ── LLM (Ollama on RunPod or Groq) ──────────────────────────────────────────
# For Groq (fastest, recommended):
#   SELFHOSTED_LLM_URL=https://api.groq.com/openai/v1
#   SELFHOSTED_LLM_MODEL=llama-3.3-70b-versatile
#   SELFHOSTED_LLM_API_KEY=gsk_your_groq_key
# For Ollama on same RunPod pod:
#   SELFHOSTED_LLM_URL=http://localhost:11434/v1
#   SELFHOSTED_LLM_MODEL=qwen2.5:7b
SELFHOSTED_LLM_URL=http://localhost:11434/v1
SELFHOSTED_LLM_MODEL=qwen2.5:7b
SELFHOSTED_LLM_API_KEY=not-needed

# ── VibeVoice TTS (self-hosted on RunPod) ───────────────────────────────────
# After running setup.sh + start.sh this will be at localhost:9000
VIBEVOICE_TTS_URL=http://localhost:9000
# Available voices: en-Carter_man, en-Davis_man, en-Emma_woman, en-Frank_man, en-Grace_woman, en-Mike_man
VIBEVOICE_VOICE=en-Carter_man

# ── MuseTalk avatar server (started by start.sh on port 7860) ───────────────
MUSETALK_SERVER_URL=http://localhost:7860

# ── Avatar image ─────────────────────────────────────────────────────────────
# Path to a clear portrait photo (JPEG/PNG, face clearly visible)
AVATAR_IMAGE=/workspace/avatar.jpg

# ── STT ─────────────────────────────────────────────────────────────────────
ASSEMBLYAI_API_KEY=your_assemblyai_key

# ── Agent behaviour ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
